{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WatchPost",
  "version": "0.2.1",
  "identifier": "com.watchpost.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "WatchPost",
        "width": 720,
        "height": 480,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true
      },
      {
        "label": "widget",
        "title": "WatchPost Widget",
        "url": "index.html",
        "width": 480,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnBottom": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Onasis Melchior",
    "shortDescription": "Lightweight monitor for your PC and remote servers",
    "longDescription": "WatchPost shows live CPU, memory, disk, and network stats in a dashboard and desktop widget. Built by Onasis Melchior.",
    "resources": [
      "gen/ABOUT.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
